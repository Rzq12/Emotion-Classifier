# ---------------------------------------------------------------------------
# Backend environment variables (copy ke `.env`, jangan pernah commit `.env`)
# ---------------------------------------------------------------------------

# --- LLM provider (Fase 3+) ---
# Pilih salah satu: groq | gemini | ollama
LLM_PROVIDER=groq

# Groq (cepat, ada free tier) — ambil key di https://console.groq.com/keys
# Satu key: pakai GROQ_API_KEY. Beberapa key (rotasi otomatis saat rate limit):
# pakai GROQ_API_KEYS (dipisah koma) ATAU GROQ_API_KEY_1..GROQ_API_KEY_N.
# Prioritas: GROQ_API_KEYS > GROQ_API_KEY_<n> > GROQ_API_KEY.
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — ambil key di https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (lokal, gratis, untuk development offline)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Vector store (Fase 3+) ---
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- API (Fase 4+) ---
API_HOST=0.0.0.0
API_PORT=7860
CORS_ALLOW_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=10

# --- Monitoring (Fase 6) ---
# Log prediksi /classify (JSONL) — input untuk src/monitoring/check_drift.py
PREDICTION_LOG_PATH=data/monitoring/predictions.jsonl

# --- MLflow tracking (Fase 2+) ---
# DB backend (sqlite) diperlukan untuk fitur terbaru + model registry.
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# --- Model artifact (Fase 4+) ---
HF_MODEL_REPO=
