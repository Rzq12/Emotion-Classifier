# ---------------------------------------------------------------------------
# Backend environment variables (copy ke `.env`, jangan pernah commit `.env`)
# ---------------------------------------------------------------------------

# --- LLM provider (Fase 3+) ---
# Pilih salah satu: anthropic | openai | ollama
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1

# --- Vector store (Fase 3+) ---
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- API (Fase 4+) ---
API_HOST=0.0.0.0
API_PORT=7860
CORS_ALLOW_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=10

# --- MLflow tracking (Fase 2+) ---
# DB backend (sqlite) diperlukan untuk fitur terbaru + model registry.
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# --- Model artifact (Fase 4+) ---
HF_MODEL_REPO=
